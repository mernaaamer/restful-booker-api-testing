    {
      "name": "6 - Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.bookingid) {",
              "  pm.collectionVariables.set('bookingId', jsonData.bookingid);",
              "  console.log('New bookingId saved: ' + jsonData.bookingid);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Merna\",\n  \"lastname\": \"Ahmed\",\n  \"totalprice\": 250,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-08-01\",\n    \"checkout\": \"2026-08-10\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
